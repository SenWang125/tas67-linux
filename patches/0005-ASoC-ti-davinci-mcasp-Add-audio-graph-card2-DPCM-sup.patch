From 929a09c4cdc677e32b400eefe0af63918cfc44df Mon Sep 17 00:00:00 2001
From: Sen Wang <sen@ti.com>
Date: Thu, 23 Apr 2026 06:22:07 -0500
Subject: [PATCH] ASoC: ti: davinci-mcasp: Add audio-graph-card2 DPCM support

Experimental support on top of the OF-graph and audio-graph-card2
normal mode patches to add DPCM mode.

Not fully tested; provided for demonstration purposes only.

Signed-off-by: Sen Wang <sen@ti.com>
---
 sound/soc/ti/davinci-mcasp.c | 261 ++++++++++++++++++++++++++++++++++-
 1 file changed, 257 insertions(+), 4 deletions(-)

diff --git a/sound/soc/ti/davinci-mcasp.c b/sound/soc/ti/davinci-mcasp.c
index f229f847eaf4..3a47ef43cb04 100644
--- a/sound/soc/ti/davinci-mcasp.c
+++ b/sound/soc/ti/davinci-mcasp.c
@@ -21,6 +21,7 @@
 #include <linux/clk.h>
 #include <linux/pm_runtime.h>
 #include <linux/of.h>
+#include <linux/of_graph.h>
 #include <linux/platform_data/davinci_asp.h>
 #include <linux/math64.h>
 #include <linux/bitmap.h>
@@ -74,6 +75,14 @@ struct davinci_mcasp_ruledata {
 	int stream;
 };
 
+enum mcasp_graph_mode {
+	MCASP_GRAPH_NONE,	/* 1:1, simple-audio-card, no of-graph endpoints */
+	MCASP_GRAPH_PORT,	/* 1:1, audio-graph-card: port { endpoint } */
+	MCASP_GRAPH_PORTS,	/* 1:N, audio-graph-card2 non-DPCM: ports { port@0; ... } */
+	MCASP_GRAPH_DPCM,	/* N:M, audio-graph-card2 DPCM: N FE DAIs, detected via */
+				/* remote "dpcm" node in the sound card DT */
+};
+
 struct davinci_mcasp {
 	struct snd_dmaengine_dai_dma_data dma_data[2];
 	struct davinci_mcasp_pdata *pdata;
@@ -124,6 +133,10 @@ struct davinci_mcasp {
 	int	max_format_width;
 	u8	active_serializers[2];
 
+	/* Audio graph support */
+	enum mcasp_graph_mode graph_mode;
+	int	num_dais;
+
 #ifdef CONFIG_GPIOLIB
 	struct gpio_chip gpio_chip;
 #endif
@@ -1486,7 +1499,35 @@ static int davinci_mcasp_hw_params(struct snd_pcm_substream *substream,
 		return -EINVAL;
 	}
 
-	ret = davinci_mcasp_set_dai_fmt(cpu_dai, mcasp->dai_fmt);
+	/*
+	 * Re-apply the per-link DAI format. When multiple links share
+	 * one McASP DAI, mcasp->dai_fmt holds the format from the last
+	 * link initialized (which may differ from the active link).
+	 * Use the active link's dai_fmt instead.
+	 */
+	struct snd_soc_pcm_runtime *rtd = snd_soc_substream_to_rtd(substream);
+	unsigned int cpu_fmt;
+
+	if (rtd->dai_link->dai_fmt) {
+		/*
+		 * audio-graph-card2 stores clock provider bits
+		 * (BP_FP etc.) separately in cpus[].ext_fmt.
+		 * Merge them after flipping, matching what
+		 * snd_soc_runtime_set_dai_fmt() does in soc-core.
+		 */
+		cpu_fmt = snd_soc_daifmt_clock_provider_flipped(
+				rtd->dai_link->dai_fmt) |
+			  rtd->dai_link->cpus[0].ext_fmt;
+	} else {
+		cpu_fmt = mcasp->dai_fmt;
+	}
+
+	dev_dbg(cpu_dai->dev,
+		"hw_params: dai_fmt=0x%x ext_fmt=0x%x cpu_fmt=0x%x\n",
+		rtd->dai_link->dai_fmt, rtd->dai_link->cpus[0].ext_fmt,
+		cpu_fmt);
+
+	ret = davinci_mcasp_set_dai_fmt(cpu_dai, cpu_fmt);
 	if (ret)
 		return ret;
 
@@ -1748,7 +1789,9 @@ static int davinci_mcasp_startup(struct snd_pcm_substream *substream,
 	int tdm_slots;
 	u8 *numevt;
 
-	/* Do not allow more then one stream per direction */
+	/*
+	 * Do not allow more than one stream per direction.
+	 */
 	if (mcasp->substreams[substream->stream])
 		return -EBUSY;
 
@@ -2029,8 +2072,39 @@ static struct snd_soc_dai_driver davinci_mcasp_dai[] = {
 
 };
 
+/*
+ * Translate of-graph endpoint to DAI ID.
+ *
+ * For DPCM: each McASP port@N maps to FE DAI N  -> return port reg
+ * For Normal/non-DPCM: all ports share DAI 0    -> return 0
+ */
+static int davinci_mcasp_of_xlate_dai_id(struct snd_soc_component *component,
+					 struct device_node *endpoint)
+{
+	struct davinci_mcasp *mcasp = snd_soc_component_get_drvdata(component);
+	struct device_node *port;
+	u32 port_reg = 0;
+
+	if (mcasp->graph_mode != MCASP_GRAPH_DPCM)
+		return 0;
+
+	/* endpoint is inside mcasp/ports/port@N — read port's reg */
+	port = of_get_parent(endpoint);
+	if (!port)
+		return -EINVAL;
+
+	of_property_read_u32(port, "reg", &port_reg);
+	of_node_put(port);
+
+	dev_dbg(component->dev, "endpoint %pOF -> DAI %d\n",
+		endpoint, port_reg);
+
+	return port_reg;
+}
+
 static const struct snd_soc_component_driver davinci_mcasp_component = {
 	.name			= "davinci-mcasp",
+	.of_xlate_dai_id	= davinci_mcasp_of_xlate_dai_id,
 	.legacy_dai_naming	= 1,
 };
 
@@ -2138,6 +2212,119 @@ static bool davinci_mcasp_have_gpiochip(struct davinci_mcasp *mcasp)
 	return device_property_present(mcasp->dev, "gpio-controller");
 }
 
+/*
+ * Detect if this McASP is used in a DPCM topology by following the
+ * OF graph back to the sound card and checking for a "dpcm" container.
+ */
+static bool mcasp_detect_dpcm(struct device_node *np)
+{
+	struct device_node *ep, *remote_ep;
+	struct device_node *port, *container, *parent;
+	bool is_dpcm = false;
+
+	/* Grab the first endpoint under this McASP node */
+	ep = of_graph_get_next_endpoint(np, NULL);
+	if (!ep)
+		return false;
+
+	/* Follow remote-endpoint phandle into the card node */
+	remote_ep = of_graph_get_remote_endpoint(ep);
+	of_node_put(ep);
+	if (!remote_ep)
+		return false;
+
+	/*
+	 * Walk the remote side: remote_ep -> port -> ports@N -> dpcm
+	 *
+	 * Card DT structure for DPCM:
+	 *   sound {
+	 *       dpcm {
+	 *           ports@0 { port@0 { endpoint { remote-ep = <&mcasp_ep>; }; }; };
+	 *           ports@1 { ... };
+	 *       };
+	 *   };
+	 */
+	port = of_get_parent(remote_ep);
+	of_node_put(remote_ep);
+	if (!port)
+		return false;
+
+	container = of_get_parent(port);
+	of_node_put(port);
+	if (!container)
+		return false;
+
+	if (of_node_name_eq(container, "ports")) {
+		parent = of_get_parent(container);
+		of_node_put(container);
+		if (parent) {
+			is_dpcm = of_node_name_eq(parent, "dpcm");
+			of_node_put(parent);
+		}
+	} else {
+		of_node_put(container);
+	}
+
+	return is_dpcm;
+}
+
+/*
+ * Parse of-graph structure to detect audio-graph-card(2) usage.
+ * Returns number of DAIs to register.
+ */
+static int davinci_mcasp_parse_of_graph(struct davinci_mcasp *mcasp,
+					struct device_node *np)
+{
+	struct device_node *port, *ports;
+	int num_dais = 0;
+
+	mcasp->graph_mode = MCASP_GRAPH_NONE;
+
+	/*
+	 * Check for audio-graph-card2 structure: ports { port@0; ... }
+	 * DPCM:  each McASP port maps to a separate FE DAI
+	 * Normal: all McASP ports share a single DAI
+	 */
+	ports = of_get_child_by_name(np, "ports");
+	if (ports) {
+		int port_count = of_get_child_count(ports);
+
+		of_node_put(ports);
+
+		if (mcasp_detect_dpcm(np)) {
+			num_dais = port_count;
+			mcasp->graph_mode = MCASP_GRAPH_DPCM;
+			dev_dbg(mcasp->dev,
+				"audio-graph DPCM: %d FE DAIs\n", num_dais);
+		} else {
+			num_dais = 1;
+			mcasp->graph_mode = MCASP_GRAPH_PORTS;
+			dev_dbg(mcasp->dev,
+				"audio-graph non-DPCM: 1 DAI, %d ports\n",
+				port_count);
+		}
+
+		return num_dais;
+	}
+
+	/*
+	 * Check for simple audio-graph-card structure:
+	 *   port { endpoint {...}; }
+	 */
+	port = of_get_child_by_name(np, "port");
+	if (port) {
+		num_dais = of_graph_get_endpoint_count(port);
+		if (num_dais > 0) {
+			mcasp->graph_mode = MCASP_GRAPH_PORT;
+			dev_dbg(mcasp->dev, "audio-graph: %d DAI(s)\n",
+				num_dais);
+		}
+		of_node_put(port);
+	}
+
+	return num_dais ? num_dais : 1;
+}
+
 static int davinci_mcasp_get_config(struct davinci_mcasp *mcasp,
 				    struct platform_device *pdev)
 {
@@ -2760,8 +2947,74 @@ static int davinci_mcasp_probe(struct platform_device *pdev)
 		goto err;
 	}
 
-	ret = devm_snd_soc_register_component(&pdev->dev, &davinci_mcasp_component,
-					      &davinci_mcasp_dai[mcasp->op_mode], 1);
+	/*
+	 * Parse audio-graph structure and register DAIs
+	 * For audio-graph-card2 with DPCM, we need multiple DAI registrations
+	 */
+	mcasp->num_dais = davinci_mcasp_parse_of_graph(mcasp, pdev->dev.of_node);
+
+	if (mcasp->graph_mode != MCASP_GRAPH_NONE && mcasp->num_dais > 1) {
+		struct snd_soc_dai_driver *dais;
+		int i;
+
+		/* Allocate DAI array for multiple audio-graph DAIs */
+		dais = devm_kcalloc(&pdev->dev, mcasp->num_dais,
+				    sizeof(*dais), GFP_KERNEL);
+		if (!dais) {
+			ret = -ENOMEM;
+			goto err;
+		}
+
+		/* Initialize each DAI from the template */
+		for (i = 0; i < mcasp->num_dais; i++) {
+			memcpy(&dais[i], &davinci_mcasp_dai[mcasp->op_mode],
+			       sizeof(*dais));
+			dais[i].name = devm_kasprintf(&pdev->dev, GFP_KERNEL,
+						      "davinci-mcasp.%d", i);
+			if (!dais[i].name) {
+				ret = -ENOMEM;
+				goto err;
+			}
+			dais[i].id = i;
+
+			/*
+			 * Each DAI needs unique stream names so DAPM can
+			 * create distinct AIF widgets per FE.
+			 */
+			if (dais[i].playback.channels_min) {
+				dais[i].playback.stream_name =
+					devm_kasprintf(&pdev->dev, GFP_KERNEL,
+						       "Playback Port %d",
+						       i);
+				if (!dais[i].playback.stream_name) {
+					ret = -ENOMEM;
+					goto err;
+				}
+			}
+			if (dais[i].capture.channels_min) {
+				dais[i].capture.stream_name =
+					devm_kasprintf(&pdev->dev, GFP_KERNEL,
+						       "Capture Port %d",
+						       i);
+				if (!dais[i].capture.stream_name) {
+					ret = -ENOMEM;
+					goto err;
+				}
+			}
+		}
+
+		dev_info(&pdev->dev, "Registering %d DAIs for audio-graph\n",
+			 mcasp->num_dais);
+
+		ret = devm_snd_soc_register_component(&pdev->dev,
+						      &davinci_mcasp_component,
+						      dais, mcasp->num_dais);
+	} else {
+		/* Simple-audio-card path or single audio-graph port */
+		ret = devm_snd_soc_register_component(&pdev->dev,
+						      &davinci_mcasp_component,
+						      &davinci_mcasp_dai[mcasp->op_mode], 1);
+	}
 
 	if (ret != 0)
 		goto err;
-- 
2.43.0

